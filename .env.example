# Required. Fill the key for the provider you use.
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# Local console dev mode.
ASSISTANT_LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4.1-mini
GEMINI_MODEL=gemini-2.5-flash
ASSISTANT_WAKE_PROVIDER=console
ASSISTANT_WAKE_PHRASE=hello there
ASSISTANT_STT_PROVIDER=console
ASSISTANT_TTS_PROVIDER=windows
ASSISTANT_SQLITE_PATH=assistant.db
ASSISTANT_RECORDING_ENABLED=false
CGO_ENABLED=1
CGO_CPPFLAGS=-IC:\Users\Harmony\code\pers\assistance\vosk-runtime\vosk-win64-0.3.45
CGO_LDFLAGS=-LC:\Users\Harmony\code\pers\assistance\vosk-runtime\vosk-win64-0.3.45 -lvosk
ASSISTANT_VOSK_MODEL_PATH=models/vosk-model-small-en-us-0.15
ASSISTANT_VOSK_SAMPLE_RATE=16000
ASSISTANT_HYBRID_LOCAL_LANGUAGES=en-US,fr-FR
ASSISTANT_HYBRID_CLOUD_LANGUAGES=ar-MA
ASSISTANT_HYBRID_MIN_CONFIDENCE=0.65
ASSISTANT_LANGUAGES=en-US,fr-FR,ar-MA
ASSISTANT_TTS_LANGUAGE_CODE=ar-XA
ASSISTANT_TTS_VOICE_NAME=
ASSISTANT_SILENCE_TIMEOUT=3s
ASSISTANT_SESSION_IDLE_TIMEOUT=45s
ASSISTANT_MAX_TURNS=12
ASSISTANT_RECORD_SECONDS=12

# Enable these for Google Cloud speech.
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\google-service-account.json
ASSISTANT_RECORD_COMMAND=arecord -f S16_LE -r 16000 -c 1 -d {seconds} {output}
ASSISTANT_PLAY_COMMAND=mpg123 {input}
ASSISTANT_WAKE_COMMAND=
